{
  "name": "@moltendb/monorepo",
  "private": true,
  "license": "MIT",
  "version": "1.5.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/maximilian27/moltendb-web"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:core": "npm run build --workspace=@moltendb-web/core",
    "build:query": "npm run build --workspace=@moltendb-web/query",
    "build:angular": "npm run build --workspace=@moltendb-web/angular",
    "build:all": "npm run build:core && npm run build:query && npm run build:angular"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@moltendb-web/core": "^1.5.1"
  },
  "dependencies": {
    "@moltendb-web/query": "^1.5.1"
  }
}
